{
  "version": 2,
  "buildCommand": "echo 'Build OK'",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/code.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/health.js": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "rewrites": [
    { "source": "/code",   "destination": "/api/code"   },
    { "source": "/health", "destination": "/api/health" },
    { "source": "/(.*)",   "destination": "/index.html" }
  ]
}
